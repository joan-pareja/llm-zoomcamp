KESTRA_POSTGRES_DB=kestra
KESTRA_POSTGRES_USER=kestra
KESTRA_POSTGRES_PASSWORD=replace-with-a-strong-password

KESTRA_USERNAME=admin@kestra.io
KESTRA_PASSWORD=replace-with-a-strong-password
KESTRA_URL=http://localhost:8080/

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL_NAME=gemini-2.5-flash

# Raw API keys are used directly by local Python/OpenAI client code.
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL_NAME=gpt-5.4-mini

TAVILY_API_KEY=your-tavily-api-key

# Kestra expects secret values to be base64-encoded.
# These should be the base64-encoded versions of the raw keys above.
# In Kestra flows, reference them without the SECRET_ prefix, e.g.
# {{ secret('GEMINI_API_KEY') }} or {{ secret('OPENAI_API_KEY') }}.
SECRET_GEMINI_API_KEY=base64-encoded-gemini-api-key
SECRET_OPENAI_API_KEY=base64-encoded-openai-api-key
SECRET_TAVILY_API_KEY=base64-encoded-tavily-api-key
